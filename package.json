{
  "name": "@sliverp/woabot",
  "version": "2.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "skills",
    "index.ts",
    "setup-entry.ts",
    "tsconfig.json",
    "openclaw.plugin.json",
    "clawdbot.plugin.json",
    "moltbot.plugin.json"
  ],
  "clawdbot": {
    "extensions": [
      "./index.ts"
    ]
  },
  "moltbot": {
    "extensions": [
      "./index.ts"
    ]
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "woabot",
      "label": "WOA Bot",
      "blurb": "通过 Server 中转连接 WPS 办公助手"
    }
  },
  "scripts": {
    "build": "tsc || true",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "bundledDependencies": [
    "ws"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "clawdbot": "*",
    "moltbot": "*",
    "openclaw": "*"
  }
}
